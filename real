<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agenda des Férias 2026</title>
    <style>
        /* CSS - Thème Sombre */
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #121212; margin: 0; padding: 20px; color: #e0e0e0; }
        h1 { text-align: center; color: #ff5252; text-transform: uppercase; letter-spacing: 2px; }
        .intro { text-align: center; color: #aaaaaa; margin-bottom: 20px; font-size: 1.1em; }
        
        .search-container { text-align: center; margin-bottom: 20px; }
        #search-input { width: 100%; max-width: 400px; padding: 12px 20px; font-size: 1em; background-color: #1e1e1e; color: #ffffff; border: 2px solid #333; border-radius: 25px; outline: none; transition: border-color 0.3s; }
        #search-input:focus { border-color: #ff5252; }

        .tabs { display: flex; justify-content: center; flex-wrap: wrap; gap: 10px; margin-bottom: 30px; }
        .tab-btn { background-color: #2c2c2c; border: none; padding: 10px 20px; border-radius: 20px; font-weight: bold; cursor: pointer; color: #e0e0e0; transition: all 0.2s; }
        .tab-btn:hover { background-color: #3d3d3d; }
        .tab-btn.active { background-color: #d32f2f; color: white; box-shadow: 0 2px 5px rgba(0,0,0,0.5); }
        
        .container { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 20px; max-width: 1200px; margin: 0 auto; }
        .month-header { grid-column: 1 / -1; font-size: 1.8em; color: #ff5252; border-bottom: 2px solid #333; padding-bottom: 10px; margin-top: 20px; text-transform: capitalize; font-weight: bold; }

        .card { background: #1e1e1e; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); padding: 20px; display: flex; flex-direction: column; transition: transform 0.2s; }
        .card:hover { transform: translateY(-5px); }
        .card.fr { border-top: 6px solid #1e40af; } 
        .card.es { border-top: 6px solid #f59e0b; } 
        
        .card-header { display: flex; justify-content: space-between; align-items: flex-start; border-bottom: 1px solid #333; padding-bottom: 10px; margin-bottom: 10px; }
        .card h2 { margin: 0; font-size: 1.3em; color: #ffffff; }
        
        /* Nouveaux styles pour la ville et le département */
        .location { font-weight: bold; color: #ff5252; margin-top: 5px; font-size: 1.1em; }
        .dept-info { font-weight: normal; color: #999999; font-size: 0.85em; margin-left: 5px; }
        
        .badge { background: #004d40; color: #80cbc4; padding: 5px 10px; border-radius: 20px; font-size: 0.85em; font-weight: bold; display: inline-block; margin-bottom: 10px; }
        .description { font-size: 0.95em; color: #aaaaaa; line-height: 1.4; flex-grow: 1; margin-bottom: 15px; }
        .date-info { font-weight: bold; color: #cccccc; margin-bottom: 10px; }
        
        .countdown { font-weight: bold; padding: 10px; border-radius: 6px; text-align: center; margin-bottom: 15px; }
        .fr .countdown { background: #0d2a63; color: #90caf9; }
        .es .countdown { background: #4a3800; color: #ffe082; }
        .past .countdown { background: #2c2c2c; color: #757575; }
        
        .btn { display: block; text-align: center; background: #d32f2f; color: white; text-decoration: none; padding: 10px; border-radius: 6px; font-weight: bold; transition: background 0.3s; }
        .btn:hover { background: #b71c1c; }
        
        .no-results { text-align: center; grid-column: 1 / -1; color: #aaaaaa; font-size: 1.2em; padding: 40px; }
    </style>
</head>
<body>

    <h1>Férias & Fêtes Majeures 2026</h1>
    <p class="intro">Le guide complet des plus grands rassemblements en France et en Espagne.</p>

    <div class="search-container">
        <input type="text" id="search-input" placeholder="🔍 Rechercher une ville, une fête, ou un département (ex: 40)...">
    </div>

    <div class="tabs" id="tabs-container">
        <button class="tab-btn active" data-filter="all">Toutes</button>
        <button class="tab-btn" data-filter="FR">🇫🇷 France</button>
        <button class="tab-btn" data-filter="ES">🇪🇸 Espagne</button>
        <button class="tab-btn" data-filter="basque">🟢🔴⚪ Pays Basque</button>
    </div>

    <div class="container" id="events-list"></div>

    <script>
        // JAVASCRIPT - Les Données avec le champ "dept" ajouté
        const events = [
            { name: "Las Fallas", city: "Valence", dept: "Communauté valencienne", country: "ES", date: "2026-03-15", visitors: "~ 1 000 000", desc: "Fête traditionnelle spectaculaire avec des sculptures géantes.", link: "https://www.fallas.com" },
            { name: "Foire au Jambon", city: "Bayonne", dept: "Pyrénées-Atlantiques (64)", country: "FR", region: "basque", date: "2026-04-02", visitors: "~ 200 000", desc: "Célébration de la gastronomie basque et du célèbre jambon.", link: "https://www.bayonne.fr" },
            { name: "Feria de Pâques", city: "Arles", dept: "Bouches-du-Rhône (13)", country: "FR", date: "2026-04-03", visitors: "~ 500 000", desc: "L'ouverture de la saison tauromachique en France.", link: "https://www.arenes-arles.com" },
            { name: "Fêtes de Biarritz", city: "Biarritz", dept: "Pyrénées-Atlantiques (64)", country: "FR", region: "basque", date: "2026-04-10", visitors: "~ 50 000", desc: "Célébrations printanières sur la côte basque.", link: "https://www.biarritz.fr" },
            { name: "Feria de Abril", city: "Séville", dept: "Andalousie", country: "ES", date: "2026-04-19", visitors: "~ 3 000 000", desc: "La plus grande fête andalouse. Casetas, flamenco...", link: "https://visitasevilla.es" },
            { name: "Fête des Bandas", city: "Condom", dept: "Gers (32)", country: "FR", date: "2026-05-08", visitors: "~ 40 000", desc: "Le plus grand rassemblement de musiques de cuivres.", link: "https://www.festivaldebandas.fr" },
            { name: "Féria de Pentecôte", city: "Nîmes", dept: "Gard (30)", country: "FR", date: "2026-05-21", visitors: "~ 1 000 000", desc: "Six jours de fête autour des magnifiques arènes romaines.", link: "https://www.nimes.fr" },
            { name: "Pentecôte à Vic", city: "Vic-Fezensac", dept: "Gers (32)", country: "FR", date: "2026-05-22", visitors: "~ 100 000", desc: "Féria gersoise réputée pour ses corridas toristas.", link: "https://www.clubtaurinvicois.com" },
            { name: "Fêtes de la Saint-Jean", city: "Saint-Jean-de-Luz", dept: "Pyrénées-Atlantiques (64)", country: "FR", region: "basque", date: "2026-06-20", visitors: "~ 80 000", desc: "Fêtes patronales basques avec feux traditionnels et pelote.", link: "https://www.saint-jean-de-luz.com" },
            { name: "Fêtes de Saint-Sever", city: "Saint-Sever", dept: "Landes (40)", country: "FR", date: "2026-06-24", visitors: "~ 40 000", desc: "Ambiance landaise authentique, cavalcade et gastronomie.", link: "https://www.saint-sever.fr" },
            { name: "Féria de l'Aluze", city: "Eauze", dept: "Gers (32)", country: "FR", date: "2026-07-05", visitors: "~ 40 000", desc: "La capitale de l'Armagnac se pare de musique.", link: "https://www.mairie-eauze.fr" },
            { name: "San Fermín", city: "Pampelune", dept: "Navarre", country: "ES", date: "2026-07-06", visitors: "~ 1 000 000", desc: "Mondialement connue pour ses encierros (lâchers de taureaux).", link: "https://www.sanfermin.com" },
            { name: "Féria de Céret", city: "Céret", dept: "Pyrénées-Orientales (66)", country: "FR", date: "2026-07-11", visitors: "~ 50 000", desc: "Féria catalane authentique, réputée pour ses spectacles taurins.", link: "https://www.ceret-de-toros.com" },
            { name: "Fêtes de la Madeleine", city: "Mont-de-Marsan", dept: "Landes (40)", country: "FR", date: "2026-07-15", visitors: "~ 400 000", desc: "L'une des plus grandes ferias de France. Dress code : en bleu et blanc !", link: "https://regiefetes.montdemarsan.fr" },
            { name: "Fêtes de Bayonne", city: "Bayonne", dept: "Pyrénées-Atlantiques (64)", country: "FR", region: "basque", date: "2026-07-15", visitors: "~ 1 000 000", desc: "L'incontournable rendez-vous en rouge et blanc.", link: "https://fetes.bayonne.fr" },
            { name: "Fêtes de Tyrosse", city: "Saint-Vincent-de-Tyrosse", dept: "Landes (40)", country: "FR", date: "2026-07-23", visitors: "~ 40 000", desc: "Une feria à taille humaine avec un fort attachement aux traditions.", link: "https://www.tyrosseville.com" },
            { name: "Fêtes d'Orthez", city: "Orthez", dept: "Pyrénées-Atlantiques (64)", country: "FR", date: "2026-07-24", visitors: "~ 40 000", desc: "Rendez-vous béarnais chaleureux autour des arènes du Pesqué.", link: "https://www.mairie-orthez.fr" },
            { name: "Fêtes de Soustons", city: "Soustons", dept: "Landes (40)", country: "FR", date: "2026-08-06", visitors: "~ 40 000", desc: "Fêtes conviviales au bord du lac, course landaise et esprit festif.", link: "https://www.mairie-soustons.fr" },
            { name: "Fêtes de Parentis", city: "Parentis-en-Born", dept: "Landes (40)", country: "FR", date: "2026-08-07", visitors: "~ 40 000", desc: "Féria de Sen Bertomiu, réputée pour ses novilladas.", link: "https://www.parentis.com" },
            { name: "Féria de Dax", city: "Dax", dept: "Landes (40)", country: "FR", date: "2026-08-12", visitors: "~ 800 000", desc: "Gros événement en rouge et blanc, musique omniprésente et arènes.", link: "https://daxlaferia.fr" },
            { name: "Féria de Béziers", city: "Béziers", dept: "Hérault (34)", country: "FR", date: "2026-08-12", visitors: "~ 700 000", desc: "Le grand rendez-vous de l'Hérault. Corridas, bodegas et ambiance.", link: "https://www.ville-beziers.fr" },
            { name: "Féria de Málaga", city: "Málaga", dept: "Andalousie", country: "ES", date: "2026-08-15", visitors: "~ 1 000 000", desc: "Fête de jour dans le centre historique et grande fête foraine de nuit.", link: "https://visita.malaga.eu" },
            { name: "Aste Nagusia", city: "Bilbao", dept: "Biscaye", country: "ES", region: "basque", date: "2026-08-22", visitors: "~ 1 500 000", desc: "La grande semaine de Bilbao, lancée par la mascotte Marijaia.", link: "https://www.bilbaoturismo.net" },
            { name: "Fêtes de Mimizan", city: "Mimizan", dept: "Landes (40)", country: "FR", date: "2026-08-25", visitors: "~ 40 000", desc: "Fêtes de fin d'été sur la côte landaise, ambiance estivale et bandas.", link: "https://www.mimizan-tourisme.com" }
        ];

        let currentSearchQuery = "";
        let currentTabFilter = "all";

        function render() {
            const list = document.getElementById('events-list');
            
            let filteredEvents = events.filter(e => {
                // On ajoute e.dept dans la recherche pour pouvoir taper "40" ou "Landes" !
                const textToSearch = (e.name + " " + e.city + " " + e.dept).toLowerCase();
                const matchesSearch = textToSearch.includes(currentSearchQuery.toLowerCase());
                
                let matchesTab = true;
                if (currentTabFilter === "FR") matchesTab = e.country === "FR";
                if (currentTabFilter === "ES") matchesTab = e.country === "ES";
                if (currentTabFilter === "basque") matchesTab = e.region === "basque";

                return matchesSearch && matchesTab;
            });

            filteredEvents.sort((a, b) => new Date(a.date) - new Date(b.date));

            if (filteredEvents.length === 0) {
                list.innerHTML = `<div class="no-results">Aucune fête ne correspond à votre recherche 🐂</div>`;
                return;
            }

            let htmlContent = "";
            let currentMonth = "";

            filteredEvents.forEach(e => {
                const eventDate = new Date(e.date);
                eventDate.setHours(0,0,0,0);
                const today = new Date();
                today.setHours(0,0,0,0);
                
                const monthName = eventDate.toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' });
                if (monthName !== currentMonth) {
                    htmlContent += `<div class="month-header">${monthName}</div>`;
                    currentMonth = monthName;
                }

                const diffTime = eventDate - today;
                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                
                let countdownText = diffDays < 0 ? "L'événement est passé" : diffDays === 0 ? "C'est aujourd'hui !" : `Dans ${diffDays} jours`;
                const flag = e.country === "FR" ? "🇫🇷" : "🇪🇸";
                
                // On affiche maintenant la ville ET le département (dans la balise span.dept-info)
                htmlContent += `
                    <div class="card ${e.country.toLowerCase()} ${diffDays < 0 ? 'past' : ''}">
                        <div class="card-header">
                            <div>
                                <h2>${flag} ${e.name}</h2>
                                <div class="location">${e.city} <span class="dept-info">(${e.dept})</span></div>
                            </div>
                        </div>
                        <span class="badge">👥 ${e.visitors} visiteurs</span>
                        <div class="date-info">📅 ${eventDate.toLocaleDateString('fr-FR', {day: 'numeric', month: 'long', year: 'numeric'})}</div>
                        <div class="description">${e.desc}</div>
                        <div class="countdown">${countdownText}</div>
                        <a href="${e.link}" target="_blank" class="btn">Visiter le site officiel</a>
                    </div>
                `;
            });

            list.innerHTML = htmlContent;
        }

        document.getElementById('search-input').addEventListener('input', function(event) {
            currentSearchQuery = event.target.value;
            render();
        });

        const tabButtons = document.querySelectorAll('.tab-btn');
        tabButtons.forEach(button => {
            button.addEventListener('click', function() {
                tabButtons.forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
                currentTabFilter = this.getAttribute('data-filter');
                render();
            });
        });

        render();
    </script>
</body>
</html>
